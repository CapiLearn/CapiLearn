POSTGRES_USER=capilearn
POSTGRES_PASSWORD=capilearn
POSTGRES_DB=capilearn
POSTGRES_PORT=55432

# Use this from the host machine while developing the FastAPI backend locally.
DATABASE_URL=postgresql+asyncpg://capilearn:capilearn@localhost:55432/capilearn

# Use this from another service in compose, such as a future backend container.
DATABASE_URL_DOCKER=postgresql+asyncpg://capilearn:capilearn@postgres:5432/capilearn

# Allow the local Vite frontend to call the FastAPI backend from the browser.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Backend observability defaults.
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-Id
OBSERVABILITY_ENABLED=true
OBSERVABILITY_CAPTURE_CONTENT=false

# LLM defaults for local development.
LLM_MODEL=openai/gpt-4o-mini
LLM_GUARDRAILS_ENABLED=true
LLM_INPUT_GUARDRAIL_MODE=regex
LLM_OUTPUT_GUARDRAIL_MODE=off
LLM_GUARDRAILS_JUDGE_ENABLED=true
LLM_GUARDRAILS_JUDGE_MODEL=openai/gpt-4o-mini
LLM_GUARDRAILS_JUDGE_TEMPERATURE=0
LLM_GUARDRAILS_FAIL_OPEN_ON_JUDGE_ERROR=true

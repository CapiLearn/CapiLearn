POSTGRES_USER=capilearn
POSTGRES_PASSWORD=capilearn
POSTGRES_DB=capilearn
POSTGRES_PORT=5432

# Use this from the host machine while developing the FastAPI backend locally.
DATABASE_URL=postgresql+psycopg://capilearn:capilearn@localhost:5432/capilearn

# Use this from another service in compose, such as a future backend container.
DATABASE_URL_DOCKER=postgresql+psycopg://capilearn:capilearn@postgres:5432/capilearn

# LLM defaults for local development.
LLM_MODEL=openai/gpt-4o-mini
LLM_GUARDRAILS_ENABLED=true
LLM_INPUT_GUARDRAIL_MODE=nemo
LLM_OUTPUT_GUARDRAIL_MODE=nemo
LLM_GUARDRAILS_CONFIG_PATH=backend/llm/guardrails/default
LLM_REGEX_GUARDRAILS_CONFIG_PATH=backend/llm/guardrails/regex
LLM_GUARDRAILS_MODEL_ENGINE=litellm
LLM_GUARDRAILS_MODEL=openai/gpt-4o-mini

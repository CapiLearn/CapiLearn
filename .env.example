POSTGRES_USER=capilearn
POSTGRES_PASSWORD=capilearn
POSTGRES_DB=capilearn
POSTGRES_PORT=55432

# Use this from the host machine while developing the FastAPI backend locally.
DATABASE_URL=postgresql+asyncpg://capilearn:capilearn@localhost:55432/capilearn

# Use this from another service in compose, such as a future backend container.
DATABASE_URL_DOCKER=postgresql+asyncpg://capilearn:capilearn@postgres:5432/capilearn

# Allow the local Vite frontend to call the FastAPI backend from the browser.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# FastAPI docs are disabled by default. Set API_DOCS_ENABLED=true only for local debugging.
API_DOCS_ENABLED=false

# Backend auth defaults. Use AUTH_MODE=clerk for real Clerk session tokens.
# On Render, set these on the FastAPI web service with production values from
# the Clerk production instance. Do not expose CLERK_SECRET_KEY or webhook
# secrets to the Vite static site.
AUTH_MODE=clerk
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----..."
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
CLERK_AUTHORIZED_PARTIES=["http://localhost:5173","http://127.0.0.1:5173"]

# Demo-only: enables unauthenticated creation of a Clerk sign-in token for the configured user.
# Leave disabled unless intentionally exposing the launch/demo admin shortcut.
# The backend resolves this email to a Clerk user id before creating a sign-in token.
# DEMO_ADMIN_LOGIN_ENABLED=true
# DEMO_ADMIN_EMAIL=admin@example.com

# The Vite static site needs this browser-safe key at build time. On Render,
# set VITE_CLERK_PUBLISHABLE_KEY=pk_live_... on the frontend static site.
# Also set VITE_API_BASE_URL to the deployed FastAPI service URL.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# VITE_API_BASE_URL=...
# Set this browser-safe flag only when the backend demo admin shortcut is intentionally enabled.
# VITE_DEMO_ADMIN_LOGIN_ENABLED=true

# Optional local/test auth mode. In AUTH_MODE=test, the backend still requires a
# bearer Authorization header, but uses these configured claims instead of Clerk.
# AUTH_MODE=test
# TEST_AUTH_CLERK_ID=user_local_dev
# TEST_AUTH_FIRST_NAME=Local
# TEST_AUTH_LAST_NAME=Dev
# TEST_AUTH_ROLE=student

# Backend observability defaults.
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-Id
OBSERVABILITY_ENABLED=true
OBSERVABILITY_CAPTURE_CONTENT=false

# Final Render/default RAG config uses pgvector with OpenAI embeddings.
# Do not use Chroma or local sentence-transformers settings for Render startup.
RAG_BACKEND=pgvector
RAG_EMBEDDING_PROVIDER=openai
RAG_MODEL_NAME=text-embedding-3-small
RAG_EMBEDDING_DIMENSIONS=384
RAG_TOP_K=5
RAG_CANDIDATE_POOL_MULTIPLIER=3
RAG_MAX_CANDIDATES=50
RAG_WRITE_RETRIEVAL_LOGS=false
# Canonical RAG index label used by admin health, retrieval logs, and conversations.
# RAG_INDEX_VERSION=full-stack-open-2026-06

# LLM defaults for local development.
# Create this key in the OpenAI Platform and enable API billing/credits.
OPENAI_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_MAX_RETRIES=0
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_GUARDRAILS_ENABLED=true
LLM_INPUT_GUARDRAIL_MODE=regex
LLM_OUTPUT_GUARDRAIL_MODE=off
LLM_GUARDRAILS_JUDGE_ENABLED=true
LLM_GUARDRAILS_JUDGE_MODEL=openai/gpt-4o-mini
LLM_GUARDRAILS_JUDGE_TEMPERATURE=0
LLM_GUARDRAILS_FAIL_OPEN_ON_JUDGE_ERROR=true
